# ============================================================
# AI Closer Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── CORE (required) ─────────────────────────────────────────

# Claude API — soul generation, conversation, memory analysis
ANTHROPIC_API_KEY=sk-ant-api03-...

# Supabase — database for clients, prospects, calls
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
SUPABASE_ACCESS_TOKEN=sbp_...          # Optional: Management API

# ── VOICE PIPELINE (required for pipecat-service) ───────────

# Deepgram — speech-to-text (Nova-2, en-AU)
DEEPGRAM_API_KEY=your_deepgram_key

# Fish Audio — text-to-speech (custom voice clone)
FISH_AUDIO_API_KEY=your_fish_audio_key
FISH_VOICE_ID=your_voice_id            # The cloned voice reference

# Node.js API URL — pipecat-service calls back to this
NODE_BASE_URL=http://localhost:3000

# ── RETELL (required for Retell voice agents) ───────────────

RETELL_API_KEY=key_...
RETELL_PHONE_NUMBER=+1234567890        # Retell phone number for outbound

# ── ELEVENLABS (required for Retell voice) ──────────────────

ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=BIvP0GN1cAtSRTxNHnWS   # Default voice ID

# ── TWILIO (required for phone calls via pipecat) ──────────

TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890        # Your Twilio phone number

# Public URL for Twilio webhooks (ngrok URL or production domain)
PUBLIC_URL=https://your-domain.ngrok-free.dev

# ── VAPI (required for Vapi agents) ─────────────────────────

VAPI_API_KEY=your_vapi_key

# ── RECALL.AI (required for Google Meet bots) ───────────────

RECALL_API_KEY=your_recall_key

# ── VIDEO — TAVUS (required for video avatars) ──────────────

TAVUS_API_KEY=your_tavus_key

# ── VIDEO — LIVEKIT (required for WebRTC rooms) ─────────────

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=your_livekit_secret

# ── DUAL-LLM (Grok fast-lane for low-latency responses) ────

# xAI — Grok-4.1-Fast for short-utterance fast lane
# Get one at https://console.x.ai/ (~$25 free credits)
XAI_API_KEY=xai-...

# ── OPTIONAL SERVICES ───────────────────────────────────────

# Anam — alternative face rendering (CARA-3)
ANAM_API_KEY=

# Calendly — scheduling integration
CALENDLY_API_KEY=

# Groq — not currently used, reserved for future
GROQ_API_KEY=

# ── SERVER CONFIG ────────────────────────────────────────────

PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development

# ── DEPLOYMENT ───────────────────────────────────────────────

# ngrok — for exposing local server to webhooks
NGROK_AUTHTOKEN=

# Railway — for production deployment
RAILWAY_TOKEN=
